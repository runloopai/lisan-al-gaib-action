{
  "name": "lisan-al-gaib-action",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "lisan-al-gaib": "out/cli.js"
  },
  "scripts": {
    "build": "tsc && ncc build out/main.js -o dist",
