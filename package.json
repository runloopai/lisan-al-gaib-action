{
  "name": "lisan-al-gaib-action",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "lisan-al-gaib": "out/cli.js"
  },
  "scripts": {
    "build": "tsc && ncc build out/main.js -o dist && cp -f node_modules/web-tree-sitter/tree-sitter.wasm node_modules/tree-sitter-starlark/tree-sitter-starlark.wasm dist/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ __tests__/",
    "local": "tsc && node out/cli.js"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0",
    "@actions/glob": "^0.5.0",
    "fast-xml-parser": "^5.5.9",
    "js-yaml": "^4.1.1",
    "lockparse": "^0.5.0",
    "semver": "^7.7.4",
    "smol-toml": "^1.6.1",
    "spdx-correct": "^3.2.0",
    "spdx-expression-parse": "^4.0.0",
    "spdx-license-ids": "^3.0.23",
    "spdx-osi": "^3.0.0",
    "spdx-satisfies": "^6.0.0",
    "tar-stream": "^3.1.8",
    "tree-sitter-starlark": "^1.3.0",
    "web-tree-sitter": "^0.24.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/semver": "^7.7.1",
    "@types/spdx-expression-parse": "^3.0.5",
    "@types/tar-stream": "^3.1.4",
    "@vercel/ncc": "^0.38.3",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
