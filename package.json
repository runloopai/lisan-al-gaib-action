    "lint": "eslint src/ __tests__/",
    "local": "tsc && node out/cli.js"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0",
    "@actions/glob": "^0.5.0",
    "lockparse": "^0.5.0",
    "smol-toml": "^1.6.1",
    "spdx-correct": "^3.2.0",
    "spdx-satisfies": "^6.0.0",
    "tree-sitter-starlark": "^1.3.0",
    "web-tree-sitter": "^0.26.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/node": "^22.0.0",
    "@vercel/ncc": "^0.38.3",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
